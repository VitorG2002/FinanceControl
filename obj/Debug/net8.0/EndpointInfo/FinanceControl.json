          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "dailyLimit": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "weeklyLimit": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "monthlyLimit": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "annualLimit": {
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
